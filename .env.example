# ────────────────────────────────────────────────────────────
# FMELi church-website — environment variables
#
# Copy to .env.local and fill in. Anything marked PUBLIC is shipped
# to the browser (do not put secrets there).
#
# In production every value below must also be set in the Vercel
# project settings before the first deploy.
# ────────────────────────────────────────────────────────────

# ── Sanity ──────────────────────────────────────────────────
# Project + dataset for the Sanity Studio + content client.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only Sanity tokens. Read = used by sanityFetch().
# Write = used by getWriteClient() / sanityWrite() for dashboard
# mutations, the public sign-up forms, and the Paystack callback.
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Shared secret for the Sanity webhook -> /api/revalidate.
SANITY_REVALIDATE_SECRET=

# ── Auth.js (pastor dashboard) ──────────────────────────────
# 32+ random bytes, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Tells Auth.js to trust the Host header (needed behind Vercel's proxy).
AUTH_TRUST_HOST=true

# Public origin used to build magic-link URLs in the login server
# action. Falls back to NEXT_PUBLIC_SITE_URL, then localhost:3000.
AUTH_URL=http://localhost:3000

# Optional. When unset, magic links are logged to the dev console
# AND surfaced on the login page so you can click through without
# SMTP. Set to "resend" / "smtp" later when wiring real email.
AUTH_EMAIL_PROVIDER=

# ── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Payments (Paystack) ─────────────────────────────────────
# Server-only secret key from the Paystack dashboard. Used by
# /api/payments/paystack/{init,verify}.
PAYSTACK_SECRET_KEY=
